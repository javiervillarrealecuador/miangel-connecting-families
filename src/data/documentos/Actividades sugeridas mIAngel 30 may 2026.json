      "name": "Construye recomendaciones"
    },
    {
      "parameters": {
        "jsCode": "const responseText = $json.candidates[0].content.parts[0].text;\nconst cleanText = responseText.replace(/```json/g, '').replace(/```/g, '').trim();\nconst parsed = JSON.parse(cleanText);\n\nconst webhookData = $('Webhook').item.json.body;\nconst perfilData = $('Consulta perfil paciente').item.json;\n\nreturn parsed.recomendaciones.map(rec => ({\n  json: {\n    nombre: rec.nombre,\n    descripcion: rec.descripcion,\n    instrucciones: Array.isArray(rec.pasos) ? rec.pasos.join('\\n') : rec.pasos,\n    duracion_estimada_minutos: rec.duracion_estimada_minutos || 15,\n    origen: 'generada_ia',\n    activa: true,\n    persona_autismo_id: webhookData.child_id,\n    familia_id: perfilData.familia_id,\n    pai_goal_id: webhookData.objetivo_id,\n    aiReasoning: rec.razon\n  }\n}));"
      },
