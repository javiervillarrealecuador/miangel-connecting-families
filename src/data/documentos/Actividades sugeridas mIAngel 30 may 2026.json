      "parameters": {
        "jsCode": "// Obtener todos los objetivos recibidos (los 3 items)\nconst items = $input.all();\n\n// Unir los títulos de los objetivos en una sola frase separada por comas\nconst listaObjetivos = items.map(item => item.json.title).join(\", \");\n\n// Retornar un ÚNICO item consolidado para que Gemini solo se ejecute 1 vez\nreturn [{\n  json: {\n    contexto: $('Webhook').item.json.body.contexto,\n    objetivos: listaObjetivos\n  }\n}];"
